# ── BACKEND CORE (Intelligence Routing) ──────────────────────────────────────
GROQ_API_KEY = os.getenv("GROQ_API_KEY", "")
SPEED_MODEL  = "llama-3.1-8b-instant"
REASON_MODEL = "llama-3.3-70b-versatile"

REASON_DOMAINS = {"linear algebra", "deep learning", "ai", "artificial intelligence"}
REASON_KEYWORDS = {"why", "prove", "derive", "compare", "explain", "interpret", "diagnose", "should"}
SPEED_OVERRIDE_KEYWORDS = {"plot", "chart", "graph", "visualize", "simulate"}

def build_speed_prompt(domain: str) -> str:
    return f"""You are a High-Speed Statistical API in {domain.upper()}.
MANDATORY RESPONSE FORMAT:
Text insight first.
Then exactly: <plotly_chart>{{...JSON...}}</plotly_chart>

STRICT RULES:
- NO markdown, NO code blocks, NO backticks.
- Plotly JSON MUST have "data" and "layout".
- Use theme="plotly_white" and color="#7c3aed"."""

def build_reason_prompt(domain: str) -> str:
    return f"""You are a Doctoral Statistical Researcher in {domain.upper()}.
MANDATORY RESPONSE FORMAT:
1. Brief summary text.
2. Exactly: <plotly_chart>{{...JSON...}}</plotly_chart>
3. Deep analysis in: <explanation>...Markdown...</explanation>

EFFICIENT DATA PROTOCOL (Use inside JSON to save speed/tokens):
- For "x", use: "RANGE(start, stop, 0.1)"
- For "y" (Normal), use: "GAUSS(mu, sigma)"
- For "y" (T-Dist), use: "TDIST(df)"
The backend will automatically expand these into 101-point high-precision arrays.

STRICT RULES:
- Plotly JSON MUST use theme="plotly_white" and color="#7c3aed"."""

def _expand_macros(spec: dict) -> dict:
    """Detect and replace RANGE/GAUSS macro strings with math arrays."""
    import math
    try:
        data_list = spec.get("data", [])
        for trace in data_list:
            # 1. Expand X-Range
            if isinstance(trace.get("x"), str) and "RANGE" in trace["x"]:
                m = re.search(r'RANGE\((.*?),(.*?),(.*?)\)', trace["x"])
                if m:
                    start, stop, step = float(m.group(1)), float(m.group(2)), float(m.group(3))
                    trace["x"] = [round(start + i*step, 3) for i in range(int((stop-start)/step) + 1)]
            
            # 2. Expand Y-Gaussian
            if isinstance(trace.get("y"), str) and "GAUSS" in trace["y"]:
                mu, sigma = 0, 1
                m = re.search(r'GAUSS\((.*?),(.*?)\)', trace["y"])
                if m: mu, sigma = float(m.group(1)), float(m.group(2))
                xs = trace.get("x", [])
                trace["y"] = [round((1/(sigma*math.sqrt(2*math.pi))) * math.exp(-0.5*((x-mu)/sigma)**2), 6) for x in xs]
            
            # 3. Expand Y-TDistribution
            if isinstance(trace.get("y"), str) and "TDIST" in trace["y"]:
                df = 1.0
                m = re.search(r'TDIST\((.*?)\)', trace["y"])
                if m: df = float(m.group(1))
                xs = trace.get("x", [])
                def tpdf(x, k):
                    return (math.gamma((k+1)/2) / (math.sqrt(k*math.pi)*math.gamma(k/2))) * (1+x*x/k)**(-(k+1)/2)
                trace["y"] = [round(tpdf(x, df), 6) for x in xs]
    except Exception: pass
    return spec

@app.post("/api/chat")
async def chat(message: str = Form(...), mode: str = Form("single"), domain: str = Form("statistics"), history: str = Form("[]")):
    msg_low = message.lower()
    should_escalate = any(sig in msg_low for sig in REASON_KEYWORDS) or mode == "multi"
    model, prompt = (REASON_MODEL, build_reason_prompt(domain)) if should_escalate else (SPEED_MODEL, build_speed_prompt(domain))
    client = Groq(api_key=GROQ_API_KEY)
    hist = json.loads(history)
    messages = [{"role": "system", "content": prompt}]
    for h in hist:
        clean_text = re.sub(r'<plotly_chart>.*?</plotly_chart>', '[Chart Displayed]', h["text"], flags=re.DOTALL)
        messages.append({"role": "assistant" if h["role"] in ["model","assistant","bot"] else "user", "content": clean_text})
    messages.append({"role": "user", "content": message})
    max_tok = 4096 if should_escalate else 2048
    response = client.chat.completions.create(model=model, messages=messages, max_tokens=max_tok)
    reply = response.choices[0].message.content.strip()

    # Recovery: wrap bare JSON
    if "<plotly_chart>" not in reply and '"data"' in reply:
        reply = re.sub(r'(\{.*?"data".*?\})', r'<plotly_chart>\1</plotly_chart>', reply, flags=re.DOTALL | re.IGNORECASE)

    # Macro Expansion Logic
    if "<plotly_chart>" in reply:
        try:
            m = re.search(r'<plotly_chart>(.*?)</plotly_chart>', reply, re.DOTALL)
            if m:
                spec = json.loads(m.group(1))
                expanded_spec = _expand_macros(spec)
                reply = reply.replace(m.group(1), json.dumps(expanded_spec))
        except Exception: pass

    return {"reply": reply}


